# Port exposed on the host AND used inside the container
MOCK_PORT=8081

# Target URL for recording / proxy mode
PROXY_TARGET=https://api.example.com

# CORS allowed origins (comma-separated, or * for all)
CORS_ORIGIN=*

# PostgreSQL (used by NestJS DatabasesModule)
PG_HOST=localhost
PG_PORT=5442
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=postgres
PG_EXTERNAL_PORT=5442
PGDATA=/var/lib/postgresql/data/pgdata

# MySQL (used by NestJS DatabasesModule)
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=stubrix
MYSQL_PASSWORD=stubrix
MYSQL_DATABASE=stubrix
MYSQL_EXTERNAL_PORT=3307

# SQLite (optional, path to .db file)
SQLITE_DB_PATH=

# Dumps directory for snapshots
DUMPS_DIR=./dumps

# Hoppscotch – Self-Hosted API Client (F8.01)
# Access: http://localhost:3100
HOPPSCOTCH_PORT=3100
HOPPSCOTCH_SECRET=stubrix-hoppscotch-secret

# Adminer – Lightweight DB web UI (F29.01)
# Access: http://localhost:8082
ADMINER_PORT=8082

# CloudBeaver – Full-featured database web IDE (F29.02)
# Access: http://localhost:8083
CLOUDBEAVER_PORT=8083

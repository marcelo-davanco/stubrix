## ==========================================================================
## Stubrix — Environment Variables Reference
##
## Copy this file to .env and adjust as needed:
##   cp .env.example .env
##
## ⚠️  IMPORTANT — two deployment modes:
##
##   LOCAL DEV  (npm run dev:api + npm run dev:ui)
##     → Use localhost + host-mapped ports (values WITHOUT comment)
##
##   DOCKER     (make stack-up / make stubrix-up)
##     → Service URLs MUST use container names (see "# Docker:" comments)
##     → The docker-compose defaults already handle this automatically
##       IF you leave those vars UNSET. Only set them to override.
##
## ==========================================================================

# --------------------------------------------------------------------------
# Stubrix Control Plane
# --------------------------------------------------------------------------
CONTROL_PORT=9090
CORS_ORIGIN=*

# --------------------------------------------------------------------------
# Mock Engine
# --------------------------------------------------------------------------
MOCK_ENGINE=wiremock                      # wiremock | mockoon
MOCK_PORT=8081
PROXY_TARGET=https://api.example.com      # Default target for recording/proxy

# Local dev:
WIREMOCK_URL=http://localhost:8081
# Docker: WIREMOCK_URL=http://wiremock:8081

# --------------------------------------------------------------------------
# PostgreSQL
# --------------------------------------------------------------------------
# Local dev: connect to host-mapped port 5442
PG_HOST=localhost
PG_PORT=5442
# Docker: PG_HOST=db-postgres  /  PG_PORT=5432

PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=postgres
PG_EXTERNAL_PORT=5442                     # Host-mapped port for docker-compose
PGDATA=/var/lib/postgresql/data/pgdata

# --------------------------------------------------------------------------
# MySQL
# --------------------------------------------------------------------------
# Local dev: connect to host-mapped port 3307
MYSQL_HOST=localhost
MYSQL_PORT=3307
# Docker: MYSQL_HOST=db-mysql  /  MYSQL_PORT=3306

MYSQL_ROOT_PASSWORD=root
MYSQL_USER=stubrix
MYSQL_PASSWORD=stubrix
MYSQL_DATABASE=stubrix
MYSQL_EXTERNAL_PORT=3307

# --------------------------------------------------------------------------
# SQLite
# --------------------------------------------------------------------------
SQLITE_DB_PATH=                           # Path to .db file (leave empty to disable)

# --------------------------------------------------------------------------
# Redis — Queue & Cache (BullMQ backend)
# --------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                           # Leave empty for local dev (no auth)
REDIS_DB=0

# --------------------------------------------------------------------------
# Dumps (snapshots)
# --------------------------------------------------------------------------
DUMPS_DIR=./dumps                         # Docker: automatically set to /app/dumps

# --------------------------------------------------------------------------
# Auth
# --------------------------------------------------------------------------
AUTH_MASTER_KEY=stubrix-dev-key           # Change in production!

# --------------------------------------------------------------------------
# LocalStack — AWS Cloud mocking (F27)
# --------------------------------------------------------------------------
LOCALSTACK_PORT=4566
# Local dev:
LOCALSTACK_URL=http://localhost:4566
# Docker: LOCALSTACK_URL=http://localstack:4566

LOCALSTACK_SERVICES=s3,sqs,sns,dynamodb,lambda,secretsmanager
LOCALSTACK_DEBUG=0
LOCALSTACK_PERSISTENCE=0

AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test                    # LocalStack accepts any value
AWS_SECRET_ACCESS_KEY=test

# --------------------------------------------------------------------------
# MinIO — Object storage (F32)
# --------------------------------------------------------------------------
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Local dev:
MINIO_URL=http://localhost:9000
# Docker: MINIO_URL=http://minio:9000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=stubrix

# --------------------------------------------------------------------------
# Kafka / Redpanda — Event-driven mocking (F16)
# --------------------------------------------------------------------------
KAFKA_PORT=9092
KAFKA_REST_PORT=8082
KAFKA_CONSOLE_PORT=8080
# Local dev:
KAFKA_REST_URL=http://localhost:8082
# Docker: KAFKA_REST_URL=http://redpanda:8082

# --------------------------------------------------------------------------
# RabbitMQ — AMQP broker (F16)
# --------------------------------------------------------------------------
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
# Local dev:
RABBITMQ_API_URL=http://localhost:15672
# Docker: RABBITMQ_API_URL=http://rabbitmq:15672

RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=%2F

# --------------------------------------------------------------------------
# GripMock — gRPC mocking (F15)
# --------------------------------------------------------------------------
GRIPMOCK_PORT=4770
GRIPMOCK_API_PORT=4771
# Local dev:
GRIPMOCK_URL=http://localhost:4771
# Docker: GRIPMOCK_URL=http://gripmock:4771

# --------------------------------------------------------------------------
# Pact Broker — Contract testing (F13)
# --------------------------------------------------------------------------
PACT_BROKER_PORT=9292
# Local dev:
PACT_BROKER_URL=http://localhost:9292
# Docker: PACT_BROKER_URL=http://pact-broker:9292

# --------------------------------------------------------------------------
# Toxiproxy — Network chaos (F26)
# --------------------------------------------------------------------------
TOXIPROXY_PORT=8474
# Local dev:
TOXIPROXY_URL=http://localhost:8474
# Docker: TOXIPROXY_URL=http://toxiproxy:8474

# --------------------------------------------------------------------------
# AI / RAG — OpenRAG + ChromaDB (F9)
# --------------------------------------------------------------------------
CHROMADB_PORT=8000
OPENRAG_PORT=8888
# Local dev:
OPENRAG_URL=http://localhost:8888
# Docker: OPENRAG_URL=http://openrag:8888

OPENAI_API_KEY=                           # Required for OpenAI-backed RAG
OLLAMA_HOST=                              # e.g. http://localhost:11434 for local Ollama

# --------------------------------------------------------------------------
# Jaeger — Distributed tracing (F28)
# --------------------------------------------------------------------------
JAEGER_UI_PORT=16686
# Local dev:
JAEGER_URL=http://localhost:16686
# Docker: JAEGER_URL=http://jaeger:16686

# OpenTelemetry exporter
OTEL_HTTP_PORT=4318
OTEL_GRPC_PORT=4317
# Local dev:
OTEL_EXPORTER_ENDPOINT=http://localhost:4318
# Docker: OTEL_EXPORTER_ENDPOINT=http://jaeger:4318

OTEL_ENABLED=false                        # Set to true to enable tracing
OTEL_SERVICE_NAME=stubrix
OTEL_SAMPLING_RATE=1.0

# --------------------------------------------------------------------------
# Prometheus — Metrics (F21)
# --------------------------------------------------------------------------
PROMETHEUS_PORT=9091
# Local dev:
PROMETHEUS_URL=http://localhost:9091
# Docker: PROMETHEUS_URL=http://prometheus:9090  (internal port differs!)

# --------------------------------------------------------------------------
# Grafana — Dashboards (F21)
# --------------------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASS=admin

# --------------------------------------------------------------------------
# Keycloak — Identity & Access Management (F33)
# --------------------------------------------------------------------------
KEYCLOAK_PORT=8180
# Local dev:
KEYCLOAK_URL=http://localhost:8180
# Docker: KEYCLOAK_URL=http://keycloak:8080  (internal port is 8080!)

KEYCLOAK_REALM=stubrix
KEYCLOAK_CLIENT_ID=stubrix-api
KEYCLOAK_CLIENT_SECRET=                   # Set after creating client in Keycloak console
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --------------------------------------------------------------------------
# Zitadel — Lightweight IAM alternative (F33)
# --------------------------------------------------------------------------
ZITADEL_PORT=8085
# Local dev:
ZITADEL_URL=http://localhost:8085
# Docker: ZITADEL_URL=http://zitadel:8080  (internal port is 8080!)

# --------------------------------------------------------------------------
# Hoppscotch — Self-Hosted API Client (F8)
# --------------------------------------------------------------------------
HOPPSCOTCH_PORT=3100
HOPPSCOTCH_SECRET=stubrix-hoppscotch-secret

# --------------------------------------------------------------------------
# Database Viewers (F29)
# --------------------------------------------------------------------------
ADMINER_PORT=8082
CLOUDBEAVER_PORT=8083

# --------------------------------------------------------------------------
# Settings & Configuration Panel (F34)
# --------------------------------------------------------------------------
CONFIG_DB_PATH=data/stubrix-config.db
COMPOSE_FILE_PATH=docker-compose.yml
COMPOSE_PROJECT_NAME=mocks-servers
DOCKER_TIMEOUT=60000
HEALTH_CHECK_INTERVAL=30000
CRYPTO_SESSION_TIMEOUT=1800000
PBKDF2_ITERATIONS=100000
CRYPTO_BCRYPT_ROUNDS=12
BACKUP_DIR=data/backups
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_COUNT=50

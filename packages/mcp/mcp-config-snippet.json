    "command": "node",
    "args": [
      "/Users/killvorak/mvps/hyper-stubrix/stubrix/packages/mcp/wiremock-mcp/src/index.js"
    ],
    "env": {
      "WIREMOCK_URL": "http://localhost:8081"

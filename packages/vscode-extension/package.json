{
  "name": "stubrix-vscode",
  "displayName": "Stubrix",
  "description": "Stubrix mock server integration for VS Code and Windsurf",
  "version": "2.3.0",
  "publisher": "stubrix",
  "icon": "resources/icon.png",
  "repository": { "type": "git", "url": "https://github.com/marcelo-davanco/stubrix" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Testing"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "stubrix",
          "title": "Stubrix",
          "icon": "resources/stubrix.svg"
        }
      ]
    },
    "views": {
      "stubrix": [
        { "id": "stubrix.mocks", "name": "Mocks" },
        { "id": "stubrix.status", "name": "Status" },
        { "id": "stubrix.scenarios", "name": "Scenarios" }
      ]
    },
    "commands": [
      { "command": "stubrix.refreshMocks", "title": "Stubrix: Refresh Mocks" },
      { "command": "stubrix.startEngine", "title": "Stubrix: Start Mock Engine" },
      { "command": "stubrix.stopEngine", "title": "Stubrix: Stop Mock Engine" },
      { "command": "stubrix.captureScenario", "title": "Stubrix: Capture Scenario" },
      { "command": "stubrix.openDocs", "title": "Stubrix: Open API Docs" },
      { "command": "stubrix.doctor", "title": "Stubrix: Doctor (Health Check)" }
    ],
    "configuration": {
      "title": "Stubrix",
      "properties": {
        "stubrix.apiUrl": {
          "type": "string",
          "default": "http://localhost:9090",
          "description": "Stubrix API base URL"
        },
        "stubrix.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Stubrix status in the status bar"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -watch -p tsconfig.json",
    "package": "npm run build && vsce package --no-dependencies",
    "install:vscode": "npm run package && code --install-extension stubrix-vscode-$(node -p \"require('./package.json').version\").vsix",
    "install:windsurf": "npm run package && (windsurf --install-extension stubrix-vscode-$(node -p \"require('./package.json').version\").vsix 2>/dev/null || /Applications/Windsurf.app/Contents/Resources/app/bin/windsurf --install-extension stubrix-vscode-$(node -p \"require('./package.json').version\").vsix)"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "@vscode/vsce": "^3.0.0"
  }
}
